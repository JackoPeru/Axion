{
  "expo": {
    "name": "Axion",
    "slug": "axion",
    "version": "1.0.2",
    "platforms": [
      "android"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#07090D"
    },
    "plugins": [
      "./plugins/withAxionApkInstaller",
      [
        "expo-camera",
        {
          "cameraPermission": "Axion usa la camera per scansionare QR presso avamposti partner.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Axion usa la posizione per verificare missioni geolocalizzate.",
          "locationWhenInUsePermission": "Axion usa la posizione per verificare missioni geolocalizzate."
        }
      ]
    ],
    "android": {
      "package": "com.axion.app",
      "versionCode": 3,
      "permissions": [
        "INTERNET",
        "REQUEST_INSTALL_PACKAGES",
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07090D"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan"
    }
  }
}
